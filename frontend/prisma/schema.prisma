generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}


datasource db {
  provider = "postgresql"
}


// --------------------------------------------------------
// 1. TRADES (Populates: Win Rate, Total P&L, Avg Confidence)
// --------------------------------------------------------
model Trade {
  id String @id @default(uuid())
  tokenIn   String 
  tokenOut  String 
  amountIn  Float 
  amountOut Float 
  priceInUsd  Float 
  priceOutUsd Float 
  valueInUsd  Float 
  valueOutUsd Float 
  realizedPnL   Float 
  pnlPercentage Float 
  isWin         Boolean 
  confidence Float
  strategy   String?
  reasoning  String? 
  txHash      String @unique
  blockNumber Int?
  status      String @default("CONFIRMED") 
  timestamp      DateTime        @default(now())
  alphaNodes     AlphaNode[]     @relation("TradeAlphaNodes")
  tradeDecisions TradeDecision[]
}

// --------------------------------------------------------
// 2. ALPHA / SIGNALS (Populates: "Alpha Purchased")
// --------------------------------------------------------

model AlphaNode {
  id                 String          @id @default(uuid())
  registrationStatus String          @default("pending")
  providerAddress    String?
  registeredAt       DateTime?
  lastHealthCheck    DateTime?
  healthStatus       String          @default("unknown")
  title              String
  nodeType           String
  description        String?
  more_context       String?
  price              Float
  status             String          @default("active")
  isPurchased        Boolean         @default(false)
  whitelisted        Boolean         @default(false)
  endpointUrl        String          @unique
  assetCoverage      String?
  granularity        String?
  historicalWinRate  Float           @default(0.0)
  reliabilityScore   Float           @default(1.0)
    ratings            Int             @default(0)
    category           String?
    apiKey             String?
    latencyMs          Float           @default(0)
    apiVersion         String?
    nodePurchases      NodePurchaseTransaction[]
    lastUpdated        DateTime        @default(now())
    updatedAt          DateTime        @updatedAt
    lastPurchaseTime   DateTime?
    createdAt          DateTime        @default(now())
    trades             Trade[]         @relation("TradeAlphaNodes")
}

// --------------------------------------------------------
// 3. EQUITY HISTORY (Populates: "Cumulative Returns" Chart)
// --------------------------------------------------------
model PortfolioSnapshot {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())
  totalValueUsd    Float 
  wrappedSolBalance Float 
  usdcBalance      Float 
  otherBalance     Float @default(0)
  alphaCount Int @default(0)
}

// --------------------------------------------------------
// 4. SETTINGS (Populates: "Wallet Balance" / Config)
// --------------------------------------------------------
model SystemState {
  key       String   @id 
  value     String
  updatedAt DateTime @updatedAt
}

// --------------------------------------------------------
// 5. ALPHA MARKET (The 48 Data Providers)
// --------------------------------------------------------
// AlphaNode model removed

// Add this model at the end of the file
model LogRating {
  id        String                    @id @default(uuid())
  txId      String                   @unique
  purchase  NodePurchaseTransaction  @relation(fields: [txId], references: [id])
  rating    Int // 1-10
  comment   String?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
}

// --------------------------------------------------------
// RATING HISTORY (Track average ratings over time)
// --------------------------------------------------------
model RatingHistory {
  id             String   @id @default(uuid())
  nodeId         String
  averageRating  Float
  totalRatings   Int      // Total number of ratings at this point
  timestamp      DateTime @default(now())

  @@index([nodeId, timestamp])
}

// --------------------------------------------------------
// 7. TRADE DECISION (Link Trade to Data Point)
// --------------------------------------------------------
model TradeDecision {
  id        String   @id @default(uuid())
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id])
  txId      String?
  context   String? // Optional: Human or external context that influenced decision
  decidedAt DateTime @default(now())
}

// --------------------------------------------------------
// 8. AGENT ACTIVITY (Agent Decisions, Node Purchases, Scores)
// --------------------------------------------------------
model AgentActivity {
  id String @id @default(uuid())
  type String 
  title       String
  description String? 
  nodeId      String? 
  nodePrice   Float? 
  nodeQuality Int? 
  utilityScore      Float? 
  alphaPerUsdcRatio Float? 
  signalValue  Float?
  signalSource String?
  tradeBias       String?
  tradeConfidence Float?
  tradeReason     String?
  riskAction String?
  riskReason String? 
  agentThought String? 
  metadata     String? 

  timestamp DateTime @default(now())
}

// --------------------------------------------------------
// 9. TRANSACTIONS (x402 payments + swap lifecycle ledger)
// --------------------------------------------------------
model Transaction {
  id String @id @default(uuid())
  txHash String @unique
  txType String
  status String @default("PENDING")
  tokenIn     String?
  tokenOut    String?
  amountIn    Float?
  amountOut   Float?
  amountUsd   Float?
  priceImpact Float?
  chainId     Int?
  network     String?
  blockNumber Int?
  fromAddress String?
  toAddress   String?
  nodeId   String?
  nodeName String?
  dataType String?
  metadata String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?
  @@index([txType, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

// --------------------------------------------------------
// 10. NODE PURCHASE TRANSACTIONS (x402 node buy ledger)
// --------------------------------------------------------
model NodePurchaseTransaction {
  id String @id @default(uuid())
  txHash String @unique
  nodeName  String
  pricePaid Float
  timestamp DateTime @default(now())
  nodeId    String?
  node      AlphaNode?   @relation(fields: [nodeId], references: [id])
  status    String       @default("CONFIRMED")
  toAddress String?
  metadata  String?
  data      String? 
  fetchedAt DateTime @default(now())
  logRating LogRating?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([nodeName, timestamp])
  @@index([timestamp])
}
