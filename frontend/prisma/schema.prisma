generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// 1. TRADES (Populates: Win Rate, Total P&L, Avg Confidence)
// --------------------------------------------------------
model Trade {
  id String @id @default(uuid())

  // Token Details
  tokenIn   String // e.g. "SOL"
  tokenOut  String // e.g. "USDC"
  amountIn  Float // Raw amount sent
  amountOut Float // Raw amount received

  // USD Values (Critical for P&L)
  priceInUsd  Float // Price of tokenIn at moment of trade
  priceOutUsd Float // Price of tokenOut at moment of trade
  valueInUsd  Float // (amountIn * priceInUsd)
  valueOutUsd Float // (amountOut * priceOutUsd)

  // Metrics
  realizedPnL   Float // (valueOutUsd - valueInUsd) - fees
  pnlPercentage Float // ((valueOutUsd - valueInUsd) / valueInUsd) * 100
  isWin         Boolean // True if realizedPnL > 0

  // AI Data
  confidence Float // 0.0 to 1.0 (Populates "Avg Confidence")
  strategy   String? // e.g. "arbitrage", "trend_follow"
  reasoning  String? // The "thought" from the AI

  // Blockchain Info
  txHash      String @unique
  blockNumber Int?
  status      String @default("CONFIRMED") // PENDING, CONFIRMED, FAILED

  timestamp      DateTime        @default(now())
  alphaNodes     AlphaNode[]     @relation("TradeAlphaNodes")
  tradeDecisions TradeDecision[]
}

// --------------------------------------------------------
// 2. ALPHA / SIGNALS (Populates: "Alpha Purchased")
// --------------------------------------------------------

model AlphaNode {
  id                 String          @id @default(uuid())
  registrationStatus String          @default("pending")
  providerAddress    String?
  apiVersion         String?         @default("1.0")
  registeredAt       DateTime?
  healthCheckUrl     String?
  lastHealthCheck    DateTime?
  healthStatus       String          @default("unknown")
  title              String
  nodeType           String
  category           String
  description        String?
  more_context       String?
  price              Float
  status             String          @default("active")
  isPurchased        Boolean         @default(false)
  whitelisted        Boolean         @default(false)
  endpointUrl        String          @unique
  // port field removed for Prisma compatibility
  icon               String?
  ratings            Int             @default(0)
  latencyMs          Int?
  assetCoverage      String?
  granularity        String?
  historicalWinRate  Float           @default(0.0)
  reliabilityScore   Float           @default(1.0)
  nodePurchases      NodePurchaseTransaction[]
  lastUpdated        DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  lastPurchaseTime   DateTime?
  createdAt          DateTime        @default(now())
  trades             Trade[]         @relation("TradeAlphaNodes")
}

