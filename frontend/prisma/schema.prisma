// --------------------------------------------------------
// 3. EQUITY HISTORY (Populates: "Cumulative Returns" Chart)
// --------------------------------------------------------
model PortfolioSnapshot {
  id        String   @id @default(uuid())
  timestamp DateTime @default(now())

  totalValueUsd    Float // Combined value of all assets
  wrappedSolBalance Float // Wrapped SOL balance in tokens
  usdcBalance      Float // USDC balance in stablecoin
  otherBalance     Float @default(0)

  // Optional: Track Alpha count at this snapshot for historical comparison
  alphaCount Int @default(0)
}

// --------------------------------------------------------
// 4. SETTINGS (Populates: "Wallet Balance" / Config)
// --------------------------------------------------------
model SystemState {
  key       String   @id // e.g. "last_sync_block", "wallet_address"
  value     String
  updatedAt DateTime @updatedAt
}

// --------------------------------------------------------
// 5. ALPHA MARKET (The 48 Data Providers)
// --------------------------------------------------------
// AlphaNode model removed

// Add this model at the end of the file
model LogRating {
  id        String                    @id @default(uuid())
  txId      String                   @unique
  purchase  NodePurchaseTransaction  @relation(fields: [txId], references: [id])
  rating    Int // 1-10
  comment   String?
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
}

// --------------------------------------------------------
// RATING HISTORY (Track average ratings over time)
// --------------------------------------------------------
model RatingHistory {
  id             String   @id @default(uuid())
  nodeId         String
  averageRating  Float
  totalRatings   Int      // Total number of ratings at this point
  timestamp      DateTime @default(now())

  @@index([nodeId, timestamp])
}

// --------------------------------------------------------
// 7. TRADE DECISION (Link Trade to Data Point)
// --------------------------------------------------------
model TradeDecision {
  id        String   @id @default(uuid())
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id])
  txId      String?
  context   String? // Optional: Human or external context that influenced decision
  decidedAt DateTime @default(now())
}

// --------------------------------------------------------
// 8. AGENT ACTIVITY (Agent Decisions, Node Purchases, Scores)
// --------------------------------------------------------
model AgentActivity {
  id String @id @default(uuid())

  // Activity Type
  type String // "node_purchase", "trade_decision", "utility_score", "signal_received", "risk_skip", "cycle_start", "cycle_end"

  // Core Data
  title       String // e.g. "Purchased Market Microstructure"
  description String? // Detailed message

  // For Node Purchases
  nodeId      String? // Reference to AlphaNode
  nodePrice   Float? // Price in USDC
  nodeQuality Int? // Quality score (0-100)

  // For Utility Scores
  utilityScore      Float? // 0.0 to 1.0
  alphaPerUsdcRatio Float? // Alpha/USDC score

  // For Signals
  signalValue  Float? // Normalized signal value
  signalSource String? // Which node/API provided it

  // For Trade Decisions
  tradeBias       String? // "BUY", "SELL", "NEUTRAL"
  tradeConfidence Float? // 0.0 to 1.0
  tradeReason     String? // AI reasoning

  // For Risk Management
  riskAction String? // "SKIP", "EXECUTE", "HOLD"
  riskReason String? // Why risk management made this decision

  // Metadata
  agentThought String? // Full strategist thought
  metadata     String? // JSON blob for extra context

  timestamp DateTime @default(now())
}

// --------------------------------------------------------
// 9. TRANSACTIONS (x402 payments + swap lifecycle ledger)
// --------------------------------------------------------
model Transaction {
  id String @id @default(uuid())

  // Canonical on-chain transaction identity
  txHash String @unique

  // X402_PAYMENT | SWAP
  txType String

  // PENDING | CONFIRMED | FAILED
  status String @default("PENDING")

  // Core transfer/swap attributes
  tokenIn     String?
  tokenOut    String?
  amountIn    Float?
  amountOut   Float?
  amountUsd   Float?
  priceImpact Float?

  // Optional chain metadata
  chainId     Int?
  network     String?
  blockNumber Int?
  fromAddress String?
  toAddress   String?

  // Optional x402/provider metadata
  nodeId   String?
  nodeName String?
  dataType String?

  // Raw metadata (JSON string)
  metadata String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  confirmedAt DateTime?

  @@index([txType, createdAt])
  @@index([status, createdAt])
  @@index([createdAt])
}

// --------------------------------------------------------
// 10. NODE PURCHASE TRANSACTIONS (x402 node buy ledger)
// --------------------------------------------------------
model NodePurchaseTransaction {
  id String @id @default(uuid())

  // Canonical on-chain transaction identity
  txHash String @unique

  // Required purchase fields
  nodeName  String
  pricePaid Float
  timestamp DateTime @default(now())

  // Optional context
  nodeId    String?
  node      AlphaNode?   @relation(fields: [nodeId], references: [id])
  status    String       @default("CONFIRMED")
  toAddress String?
  metadata  String?

  // Data payload (signal/data point)
  data      String? // JSON data or signal information
  fetchedAt DateTime @default(now())

  // Ratings
  logRating LogRating?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nodeName, timestamp])
  @@index([timestamp])
}
